{
	"$id": "docs.json.ts--production-planner--lib--CanConvertTypeJsonDefs",
	"type": "object",
	"required": ["pool"],
	"additionalProperties": false,
	"$defs": {
		"amount_string": {
			"type": "string",
			"pattern": "^\\d+(?:\\.\\d{1,6})?$"
		},
		"amount_string_flexible": {
			"oneOf": [
				{"$ref": "#/$defs/amount_string"},
				{
					"type": "string",
					"pattern": "^\\d*(?:\\.\\d{1,6})$"
				},
				{
					"type": "string",
					"pattern": "^\\d+$"
				}
			]
		},
		"numeric_string": {
			"type": "string",
			"pattern": "^-?(?:\\d*\\.\\d+|\\d+(?:\\.\\d+)?)$"
		},
		"number_arg": {
			"oneOf": [
				{"type": "number", "minimum": 0, "multipleOf": 0.000001},
				{"$ref": "#/$defs/amount_string"},
				{"$ref": "#/$defs/CanConvertTypeJson"}
			]
		},
		"IntermediaryNumber": {
			"type": "object",
			"required": ["type", "value"],
			"additionalProperties": false,
			"properties": {
				"type": {"type": "string", "const": "IntermediaryNumber"},
				"value": {
					"oneOf": [
						{"$ref": "#/$defs/amount_string_flexible"},
						{"$ref": "#/$defs/numeric_string"},
						{
							"type": "string",
							"pattern": "^(-?\\d+(?:\\.\\d+))e([+-])(\\d+)$"
						}
					]
				}
			}
		},
		"IntermediaryCalculation": {
			"type": "object",
			"required": ["type", "left", "operation", "right"],
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string",
					"const": "IntermediaryCalculation"
				},
				"left": {"$ref": "#/$defs/CanConvertTypeJson"},
				"operation": {
					"type": "string",
					"enum": [
						"+",
						"-",
						"*",
						"x",
						"/",
						"%"
					]
				},
				"right": {"$ref": "#/$defs/CanConvertTypeJson"}
			}
		},
		"TokenScan": {
			"type": "object",
			"required": ["type", "value"],
			"additionalProperties": false,
			"properties": {
				"type": {"type": "string", "const": "TokenScan"},
				"value": {"type": "string"}
			}
		},
		"CanConvertTypeJson": {
			"oneOf": [
				{"$ref": "#/$defs/IntermediaryNumber"},
				{"$ref": "#/$defs/IntermediaryCalculation"},
				{"$ref": "#/$defs/TokenScan"}
			]
		}
	}
}
